generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Skill {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String
  level Int
  color String //bg-blue-500
}

model Trait {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  text  String
}

model Project {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  title       String 
  description String 
  image       String
  tags        String[]
  github      String 
  demo        String
}

model Contact {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
